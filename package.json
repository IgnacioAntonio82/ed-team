{
  "name": "ed-team",
  "version": "1.0.7",
  "description": "Software Cargar, Edicion Eliminacion Productos",
  "main": "src/index.js",
  "type": "commonjs",
  "author": "OWNISOFT",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "mongoose": "^9.2.3"
  },
  "devDependencies": {
    "electron": "^40.8.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ownisoft.edteam",
    "productName": "ED Team",
    "artifactName": "ED-Team-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "IgnacioAntonio82",
        "repo": "ed-team",
        "vPrefixedTagName": true
      }
    ],
    "files": [
      "!dist",
      "**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "differentialPackage": false
    }
  }
}